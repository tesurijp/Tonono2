<Window x:Class="Tonono2.UI.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tonono2 Information" Height="450" Width="600"
        WindowStyle="ToolWindow" Topmost="True" Background="#F0F0F0">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="全般">
                <StackPanel Margin="10">
                    <TextBlock Text="Tonono2 SKK-Like System" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Version 1.1.0" Margin="0,0,0,5"/>
                    <TextBlock Text=".NET 10 (C#) / WPF" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="設定パス:" FontWeight="Bold"/>
                    <TextBox Text="{Binding ConfigPath, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,10" Background="Transparent" BorderThickness="0"/>
                    
                    <TextBlock Text="読み込み済み辞書:" FontWeight="Bold"/>
                    <ListBox ItemsSource="{Binding DictionaryPaths}" Margin="0,0,0,10"/>

                    <TextBlock Text="Vi互換アプリ (ESCの特殊処理):" FontWeight="Bold"/>
                    <ListBox ItemsSource="{Binding ViCompatibleApps}" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="仮名変換">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="ローマ字変換" FontWeight="Bold" />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding RomajiEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ローマ字" Binding="{Binding Key}" Width="100"/>
                            <DataGridTextColumn Header="かな" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="撥音・促音加工" FontWeight="Bold"/>
                    <DataGrid Grid.Row="3" ItemsSource="{Binding MoraModifierEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="入力" Binding="{Binding Key}" Width="100"/>
                            <DataGridTextColumn Header="修飾" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="4" Text="末尾撥音補完" FontWeight="Bold"/>
                    <DataGrid Grid.Row="5" ItemsSource="{Binding MoraAutoCompleteEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="入力" Binding="{Binding Key}" Width="100"/>
                            <DataGridTextColumn Header="補完" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="全角直接入力">
                <DataGrid ItemsSource="{Binding ZenkakuEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="変換元" Binding="{Binding Key}" Width="100"/>
                        <DataGridTextColumn Header="全角" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
