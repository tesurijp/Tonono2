<Window x:Class="Tonono2.UI.InfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tonono2 Information" Height="450" Width="600"
        WindowStyle="ToolWindow" Topmost="True" Background="#F0F0F0">
    <Grid Margin="10">
        <TabControl>
            <TabItem Header="General">
                <StackPanel Margin="10">
                    <TextBlock Text="Tonono2 SKK-Like System" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    <TextBlock Text="Version 1.1.0" Margin="0,0,0,5"/>
                    <TextBlock Text=".NET 10 (C#) / WPF" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Config Path:" FontWeight="Bold"/>
                    <TextBox Text="{Binding ConfigPath, Mode=OneWay}" IsReadOnly="True" Margin="0,0,0,10" Background="Transparent" BorderThickness="0"/>
                    
                    <TextBlock Text="Loaded Dictionaries:" FontWeight="Bold"/>
                    <ListBox ItemsSource="{Binding DictionaryPaths}" Height="100" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Romaji Table">
                <DataGrid ItemsSource="{Binding RomajiEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Romaji" Binding="{Binding Key}" Width="100"/>
                        <DataGridTextColumn Header="Kana" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Zenkaku Table">
                <DataGrid ItemsSource="{Binding ZenkakuEntries}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Original" Binding="{Binding Key}" Width="100"/>
                        <DataGridTextColumn Header="Zenkaku" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
